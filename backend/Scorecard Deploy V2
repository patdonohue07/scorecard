# ── SIGNAL LOGIC (mirrors JS exactly) ─────────────────────────────────────────

def percentile_rank(distribution, value):
    """What % of historical shocks are <= value. Matches JS pr() function."""
    count = sum(1 for x in distribution if x <= value)
    return count / len(distribution) * 100

def median(arr):
    """Matches JS med() function."""
    if not arr:
        return 0
    return statistics.median(arr)

def compute_signal(pair, lead_prev_close, lead_open, target_prev_close, target_open, volume_pass=True):
    """
    Returns dict with:
      shock, percentile, direction ('UP'/'DN'/None), action string, filters_failed list
    """
    ol = lead_open / lead_prev_close - 1      # lead overnight gap
    ot = target_open / target_prev_close - 1  # target overnight gap
    shock = ol - pair["beta"] * ot
    pct = percentile_rank(pair["sk"], shock)

    # direction
    if pct >= pair["th"]:
        direction = "UP"
    elif pct <= pair["lo"]:
        direction = "DN"
    else:
        direction = None

    ok = direction is not None
    filters_failed = []

    if not ok:
        filters_failed.append(f"Shock {pct:.1f}th — need ≥{pair['th']} or ≤{pair['lo']}")

    # TOW filter
    if ok and pair["tow"] and pair["to"]:
        tc = pair["to"][-1]
        tm = median(pair["to"])
        if tc < tm:
            ok = False
            filters_failed.append("TOW below median")

    # volume filter
    if ok and pair["vo"] and not volume_pass:
        ok = False
        filters_failed.append("Volume filter fail")

    # same-side filter
    if ok and pair["ss"]:
        same_side = (ol > 0 and ot > 0) or (ol < 0 and ot < 0)
        if not same_side:
            ok = False
            filters_failed.append("Gaps diverge")

    if ok:
        if direction == "UP":
            action = f"SHORT {pair['lead']} / LONG {pair['target']}"
        else:
            action = f"LONG {pair['lead']} / SHORT {pair['target']}"
    else:
        direction = None
        action = "No trade"

    return {
        "shock": shock,
        "percentile": pct,
        "lead_gap": ol,
        "target_gap": ot,
        "direction": direction,
        "action": action,
        "filters_failed": filters_failed,
    }

# ── PRICE FETCHING ─────────────────────────────────────────────────────────────

def get_prices(data_client, symbols):
    """
    Returns dict: {symbol: {"prev_close": float, "open": float}}
    Uses daily bars — prev_close = yesterday's close, open = today's open.
    """
    today = datetime.date.today()
    # fetch last 3 days of daily bars to ensure we have prev close
    start = today - datetime.timedelta(days=5)

    request = StockBarsRequest(
        symbol_or_symbols=symbols,
        timeframe=TimeFrame.Day,
        start=start,
        end=today,
    )
    bars = data_client.get_stock_bars(request)

    prices = {}
    for symbol in symbols:
        symbol_bars = bars[symbol]
        if len(symbol_bars) < 2:
            raise ValueError(f"Not enough bars for {symbol}")
        # second to last bar = yesterday, last bar = today
        prev_bar = symbol_bars[-2]
        today_bar = symbol_bars[-1]
        prices[symbol] = {
            "prev_close": float(prev_bar.close),
            "open": float(today_bar.open),
        }
    return prices

# ── ORDER PLACEMENT ────────────────────────────────────────────────────────────

def place_pair_trade(trading_client, lead, target, direction, position_size, lead_price, target_price):
    """
    direction == 'UP': SHORT lead, LONG target
    direction == 'DN': LONG lead, SHORT target
    Dollar neutral: POSITION_SIZE dollars each leg.
    """
    lead_qty  = max(1, int(position_size / lead_price))
    target_qty = max(1, int(position_size / target_price))

    if direction == "UP":
        lead_side   = OrderSide.SELL   # short lead
        target_side = OrderSide.BUY    # long target
    else:
        lead_side   = OrderSide.BUY    # long lead
        target_side = OrderSide.SELL   # short target

    orders = []
    for symbol, side, qty in [
        (lead, lead_side, lead_qty),
        (target, target_side, target_qty),
    ]:
        req = MarketOrderRequest(
            symbol=symbol,
            qty=qty,
            side=side,
            time_in_force=TimeInForce.DAY,
        )
        order = trading_client.submit_order(req)
        orders.append(order)
        print(f"  ORDER: {side.value.upper()} {qty} {symbol} @ market")

    return orders

