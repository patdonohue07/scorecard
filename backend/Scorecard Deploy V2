            "lead_prev_close":  round(lp["prev_close"], 4),
            "lead_open":        round(lp["open"], 4),
            "target_prev_close":round(tp["prev_close"], 4),
            "target_open":      round(tp["open"], 4),
            "lead_gap":         round(ol * 100, 4),
            "target_gap":       round(ot * 100, 4),
            "shock":            round(sig["shock"] * 100, 4),
            "percentile":       round(sig["percentile"], 2),
            "direction":        sig["direction"],
            "action":           sig["action"],
        })

    try:
        with open(SIGNALS_OUTPUT_PATH, "w") as f:
            json.dump(output, f, indent=2)
        print(f"\nSignals written to: {SIGNALS_OUTPUT_PATH}")
    except Exception as e:
        print(f"\nERROR writing signals JSON: {e}")

if __name__ == "__main__":
    run()


