        "# ============================================================\n",
        "# Quantile — Pairs Trading Data Pull\n",
        "# Google Colab | yfinance | Daily OHLCV\n",
        "# ============================================================\n",
        "\n",
        "# ---- 1. Install dependencies ----\n",
        "!pip install yfinance pandas --quiet\n",
        "\n",
        "import yfinance as yf\n",
        "import pandas as pd\n",
        "from datetime import datetime\n",
        "\n",
        "# ---- 2. Define universe ----\n",
        "\n",
        "PAIRS = [\n",
        "    # Active pairs (verified)\n",
        "    (\"V\",   \"MA\"),\n",
        "    (\"LOW\", \"HD\"),\n",
        "    (\"PG\",  \"CL\"),\n",
        "    (\"MS\",  \"GS\"),\n",
        "    (\"BAC\", \"JPM\"),\n",
        "    # Candidates — Financials\n",
        "    (\"AXP\", \"DFS\"),\n",
        "    (\"BLK\", \"STT\"),\n",
        "    # Candidates — Energy\n",
        "    (\"XOM\", \"CVX\"),\n",
        "    (\"COP\", \"EOG\"),\n",
        "    (\"SLB\", \"HAL\"),\n",
        "    # Candidates — Staples\n",
        "    (\"KO\",  \"PEP\"),\n",
        "    (\"MCD\", \"YUM\"),\n",
        "    # Candidates — Retail\n",
        "    (\"DG\",  \"DLTR\"),\n",
        "    (\"TGT\", \"WMT\"),\n",
        "    (\"COST\",\"BJ\"),\n",
        "    # Candidates — Tech\n",
        "    (\"AMD\", \"NVDA\"),\n",
        "    (\"MSFT\",\"GOOGL\"),\n",
        "    # Candidates — Airlines\n",
        "    (\"DAL\", \"UAL\"),\n",
        "    (\"LUV\", \"ALK\"),\n",
        "    # Candidates — Pharma\n",
        "    (\"JNJ\", \"ABT\"),\n",
        "    (\"PFE\", \"MRK\"),\n",
        "]\n",
        "\n",
        "# Flatten to unique tickers\n",
        "TICKERS = sorted(set(t for pair in PAIRS for t in pair))\n",
        "print(f\"Total unique tickers: {len(TICKERS)}\")\n",
        "print(TICKERS)\n",
        "\n",
        "# ---- 3. Define date range ----\n",
        "START = \"2018-01-01\"\n",
        "END   = datetime.today().strftime(\"%Y-%m-%d\")\n",
        "print(f\"\\nPulling: {START} → {END}\")\n",
        "\n",
        "# ---- 4. Download data ----\n",
        "raw = yf.download(\n",
        "    tickers   = TICKERS,\n",
        "    start     = START,\n",
        "    end       = END,\n",
        "    interval  = \"1d\",\n",
        "    auto_adjust = True,   # adjusts for splits/dividends\n",
        "    group_by  = \"ticker\",\n",
        "    threads   = True,\n",
        ")\n",
        "\n",
        "# ---- 5. Reshape to clean long format ----\n",
        "# Stack into: Date | Ticker | Open | High | Low | Close | Volume\n",
        "\n",
        "frames = []\n",
        "for ticker in TICKERS:\n",
        "    try:\n",
        "        df = raw[ticker][[\"Open\", \"High\", \"Low\", \"Close\", \"Volume\"]].copy()\n",
        "        df = df.dropna(how=\"all\")\n",
        "        df[\"Ticker\"] = ticker\n",
        "        df = df.reset_index()\n",
        "        frames.append(df)\n",
        "    except KeyError:\n",
        "        print(f\"WARNING: {ticker} not found in download\")\n",
        "\n",
        "data = pd.concat(frames, ignore_index=True)\n",
        "data = data[[\"Date\", \"Ticker\", \"Open\", \"High\", \"Low\", \"Close\", \"Volume\"]]\n",
        "data = data.sort_values([\"Ticker\", \"Date\"]).reset_index(drop=True)\n",
        "\n",
        "print(f\"\\nTotal rows: {len(data):,}\")\n",
        "print(f\"Date range: {data['Date'].min()} → {data['Date'].max()}\")\n",
        "print(f\"Tickers:    {data['Ticker'].nunique()}\")\n",
        "print(data.head(10))\n",
        "\n",
        "# ---- 6. Export ----\n",
        "FILENAME = f\"quantile_ohlcv_{START[:4]}_{END[:4]}.csv\"\n",
        "data.to_csv(FILENAME, index=False)\n",
        "print(f\"\\nSaved: {FILENAME}  ({len(data):,} rows)\")\n",
        "\n",
        "# ---- 7. Sanity check per ticker ----\n",
        "summary = (\n",
        "    data.groupby(\"Ticker\")\n",
        "    .agg(rows=(\"Date\",\"count\"), start=(\"Date\",\"min\"), end=(\"Date\",\"max\"))\n",
        "    .reset_index()\n",
        ")\n",
        "print(\"\\nPer-ticker summary:\")\n",
        "print(summary.to_string(index=False))"
