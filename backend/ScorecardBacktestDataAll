        "# ============================================================\n",
        "# Quantile — OHLCV Pull (Wide Format, Backtest-Ready)\n",
        "# ============================================================\n",
        "\n",
        "!pip install yfinance pandas --quiet\n",
        "\n",
        "import yfinance as yf\n",
        "import pandas as pd\n",
        "from datetime import datetime\n",
        "from google.colab import files\n",
        "\n",
        "# ---- Pairs universe ----\n",
        "PAIRS = [\n",
        "    (\"V\",    \"MA\"),\n",
        "    (\"LOW\",  \"HD\"),\n",
        "    (\"PG\",   \"CL\"),\n",
        "    (\"MS\",   \"GS\"),\n",
        "    (\"BAC\",  \"JPM\"),\n",
        "    (\"AXP\",  \"COF\"),\n",
        "    (\"BLK\",  \"STT\"),\n",
        "    (\"XOM\",  \"CVX\"),\n",
        "    (\"COP\",  \"EOG\"),\n",
        "    (\"SLB\",  \"HAL\"),\n",
        "    (\"KO\",   \"PEP\"),\n",
        "    (\"MCD\",  \"YUM\"),\n",
        "    (\"DG\",   \"DLTR\"),\n",
        "    (\"TGT\",  \"WMT\"),\n",
        "    (\"COST\", \"BJ\"),\n",
        "    (\"AMD\",  \"NVDA\"),\n",
        "    (\"MSFT\", \"GOOGL\"),\n",
        "    (\"DAL\",  \"UAL\"),\n",
        "    (\"LUV\",  \"ALK\"),\n",
        "    (\"JNJ\",  \"ABT\"),\n",
        "    (\"PFE\",  \"MRK\"),\n",
        "]\n",
        "\n",
        "TICKERS = sorted(set(t for pair in PAIRS for t in pair))\n",
        "START   = \"2018-01-01\"\n",
        "END     = datetime.today().strftime(\"%Y-%m-%d\")\n",
        "\n",
        "print(f\"Downloading {len(TICKERS)} tickers: {START} → {END}\")\n",
        "\n",
        "# ---- Download ----\n",
        "raw = yf.download(\n",
        "    tickers     = TICKERS,\n",
        "    start       = START,\n",
        "    end         = END,\n",
        "    interval    = \"1d\",\n",
        "    auto_adjust = True,\n",
        "    group_by    = \"ticker\",\n",
        "    threads     = True,\n",
        ")\n",
        "\n",
        "# ---- Build one wide table per OHLCV field ----\n",
        "fields = [\"Open\", \"High\", \"Low\", \"Close\", \"Volume\"]\n",
        "\n",
        "wide_frames = {}\n",
        "for field in fields:\n",
        "    df = pd.DataFrame(index=raw.index)\n",
        "    for ticker in TICKERS:\n",
        "        try:\n",
        "            df[ticker] = raw[ticker][field]\n",
        "        except KeyError:\n",
        "            print(f\"WARNING: {ticker} missing for {field}\")\n",
        "    wide_frames[field] = df\n",
        "\n",
        "# ---- Stack into single wide CSV ----\n",
        "combined = pd.concat(\n",
        "    [wide_frames[f].add_prefix(f\"{f}_\") for f in fields],\n",
        "    axis=1\n",
        ")\n",
        "combined.index = pd.to_datetime(combined.index).date\n",
        "combined.index.name = \"Date\"\n",
        "combined = combined.sort_index()\n",
        "\n",
        "print(f\"\\nShape:      {combined.shape}\")\n",
        "print(f\"Rows:       {len(combined):,}\")\n",
        "print(f\"Columns:    {len(combined.columns):,}\")\n",
        "print(f\"Date range: {combined.index.min()} → {combined.index.max()}\")\n",
        "\n",
        "# ---- Sanity check ----\n",
        "close_cols = [c for c in combined.columns if c.startswith(\"Close_\")]\n",
        "missing = combined[close_cols].isnull().sum()\n",
        "missing = missing[missing > 0]\n",
        "if len(missing) > 0:\n",
        "    print(\"Missing data:\")\n",
        "    print(missing)\n",
        "else:\n",
        "    print(\"No missing values\")\n",
        "\n",
        "# ---- Save & download ----\n",
        "combined.to_csv(\"allpricedataFINAL.csv\")\n",
        "print(f\"\\nSaved: allpricedataFINAL.csv\")\n",
        "files.download(\"allpricedataFINAL.csv\")"
