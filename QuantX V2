              <div style={{ fontSize:12, color:C.dimmer }}>
                {result ? `${result.p.toFixed(1)}th — need ≥${pair.th} or ≤${pair.lo}` : "Enter today's opening prices below"}
              </div>
            )}
          </div>

          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8, marginBottom:8 }}>
            <PriceInput ticker={pair.lead} sub="prev close" value={v.lpc} onChange={val=>upd("lpc",val)}/>
            <PriceInput ticker={pair.lead} sub="today open" value={v.lo} onChange={val=>upd("lo",val)}/>
          </div>
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8 }}>
            <PriceInput ticker={pair.target} sub="prev close" value={v.tpc} onChange={val=>upd("tpc",val)}/>
            <PriceInput ticker={pair.target} sub="today open" value={v.to} onChange={val=>upd("to",val)}/>
