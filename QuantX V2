function pct(dist, v) { return (dist.filter(x => x <= v).length / dist.length) * 100; }
function calcSig(pair, lpc, lo, tpc, to) {
  const ol = lo/lpc-1, ot = to/tpc-1, shock = ol-pair.beta*ot, p = pct(pair.sk, shock);
  return { ol, ot, shock, p, dir: p>=pair.th ? "UP" : p<=pair.lo ? "DN" : null };
}

// ── PERCENTILE BAR ─────────────────────────────────────────────────────────────
function PctBar({ value, th, lo }) {
  const has = value !== null && value !== undefined;
  const firing = has && (value >= th || value <= lo);
  const isUp = has && value >= th;
  const barColor = firing ? (isUp ? C.green : C.red) : C.accent;
  return (
    <div style={{ marginBottom:16 }}>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:6 }}>
        <span style={{ fontSize:10, color:C.dimmer, letterSpacing:"0.08em", fontWeight:500 }}>PERCENTILE</span>
        <span style={{ fontSize:12, fontWeight:600, color:has?barColor:C.dimmest, fontFamily:C.mono }}>
          {has ? `${value.toFixed(1)}th` : "—"}
        </span>
      </div>
      <div style={{ height:2, background:"rgba(255,255,255,0.06)", borderRadius:2, position:"relative" }}>
        <div style={{ position:"absolute", left:0, width:`${lo}%`, height:"100%", background:"rgba(239,68,68,0.15)", borderRadius:"2px 0 0 2px" }}/>
        <div style={{ position:"absolute", right:0, width:`${100-th}%`, height:"100%", background:"rgba(34,197,94,0.15)", borderRadius:"0 2px 2px 0" }}/>
        {has && (
          <div style={{
            position:"absolute", left:0, height:"100%", width:`${value}%`,
            background:barColor, borderRadius:2,
            transition:"width 0.4s cubic-bezier(.4,0,.2,1), background 0.3s ease",
            boxShadow: firing ? `0 0 8px ${barColor}50` : "none",
          }}/>
        )}
        <div style={{ position:"absolute", left:`${lo}%`, top:-3, width:1, height:8, background:"rgba(239,68,68,0.4)" }}/>
        <div style={{ position:"absolute", left:`${th}%`, top:-3, width:1, height:8, background:"rgba(34,197,94,0.4)" }}/>
      </div>
      <div style={{ display:"flex", justifyContent:"space-between", marginTop:5 }}>
        <span style={{ fontSize:9, color:"rgba(239,68,68,0.4)", letterSpacing:"0.05em" }}>SHORT ≤{lo}</span>
        <span style={{ fontSize:9, color:"rgba(34,197,94,0.4)", letterSpacing:"0.05em" }}>LONG ≥{th}</span>
      </div>
    </div>
  );
}

// ── PRICE INPUT ────────────────────────────────────────────────────────────────
function PriceInput({ ticker, sub, value, onChange }) {
  const [focused, setFocused] = useState(false);
  const id = `pi-${ticker}-${sub}`;
  return (
    <div onClick={() => document.getElementById(id)?.focus()} style={{
      background: focused ? C.accentDim : C.surface,
      border:`1px solid ${focused ? C.accentBorder : C.border}`,
      borderRadius:10, padding:"12px 14px", cursor:"text",
      transition:"border-color 0.15s, background 0.15s",
    }}>
      <div style={{ display:"flex", justifyContent:"space-between", marginBottom:5 }}>
        <span style={{ fontSize:9, color:C.dimmer, letterSpacing:"0.1em", textTransform:"uppercase", fontWeight:500 }}>{sub}</span>
        <span style={{ fontSize:10, fontWeight:700, color:focused?C.accent:C.dim, letterSpacing:"0.04em", transition:"color 0.15s" }}>{ticker}</span>
      </div>
      <input
        id={id} type="number" step="0.01" placeholder="0.00"
        value={value} onChange={e => onChange(e.target.value)}
        onFocus={() => setFocused(true)} onBlur={() => setFocused(false)}
        style={{
          width:"100%", background:"transparent", border:"none", outline:"none",
          color:value?C.white:"rgba(255,255,255,0.15)",
          fontSize:20, fontWeight:600, fontFamily:C.font, letterSpacing:"-0.03em",
        }}
      />
    </div>
  );
}

// ── PAIR ACCORDION ─────────────────────────────────────────────────────────────
function PairAccordion({ pair, open, onToggle, onLogTrade }) {
  const [v, setV] = useState({ lpc:"", lo:"", tpc:"", to:"" });
  const upd = (k, val) => setV(p => ({ ...p, [k]: val }));
  const filled = +v.lpc && +v.lo && +v.tpc && +v.to;
  const result = filled ? calcSig(pair, +v.lpc, +v.lo, +v.tpc, +v.to) : null;
  const hasSignal = !!result?.dir;
  const isUp = result?.dir === "UP";
  const sc = isUp ? C.green : hasSignal ? C.red : null;

  const handleLog = () => {
    if (!result?.dir) return;
    onLogTrade({
      id:         Date.now().toString(),
      date:       new Date().toISOString().slice(0, 10),
      time:       new Date().toLocaleTimeString("en-US", { hour:"2-digit", minute:"2-digit", hour12:false }),
      pair:       `${pair.lead}/${pair.target}`,
      direction:  result.dir,
      action:     isUp ? `Short ${pair.lead} · Long ${pair.target}` : `Long ${pair.lead} · Short ${pair.target}`,
      percentile: result.p.toFixed(1),
      lead_gap:   (result.ol * 100).toFixed(3),
      target_gap: (result.ot * 100).toFixed(3),
      entry_lead:   +v.lo,
      entry_target: +v.to,
      outcome:    "pending",
      pnl:        null,
      notes:      "",
    });
  };

  return (
    <div style={{
      background:C.surface,
      border:`1px solid ${hasSignal?(isUp?C.greenBorder:C.redBorder):C.border}`,
      borderRadius:14, overflow:"hidden",
      transition:"border-color 0.25s ease",
      boxShadow: hasSignal ? `0 0 20px ${isUp?"rgba(34,197,94,0.08)":"rgba(239,68,68,0.08)"}` : "none",
    }}>
      <button onClick={onToggle} style={{
        width:"100%", background:"transparent", border:"none",
        padding:"18px 20px", cursor:"pointer", textAlign:"left",
        display:"flex", justifyContent:"space-between", alignItems:"center",
      }}>
        <div>
          <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:3, flexWrap:"wrap" }}>
            <span style={{ fontSize:17, fontWeight:600, color:C.white, letterSpacing:"-0.02em" }}>{pair.lead}</span>
            <span style={{ color:C.dimmest, fontSize:14 }}>/</span>
            <span style={{ fontSize:17, fontWeight:500, color:C.dim, letterSpacing:"-0.02em" }}>{pair.target}</span>
            {hasSignal && (
              <span style={{
                fontSize:9, fontWeight:700, letterSpacing:"0.1em",
                color:sc, background:isUp?C.greenDim:C.redDim,
                border:`1px solid ${isUp?C.greenBorder:C.redBorder}`,
                padding:"2px 8px", borderRadius:20,
              }}>{isUp?"▲ LONG":"▼ SHORT"}</span>
            )}
          </div>
          <span style={{ fontSize:11, color:C.dimmer }}>{pair.label}</span>
        </div>
        <div style={{
          width:28, height:28, borderRadius:"50%", flexShrink:0,
          border:`1px solid ${open?C.accentBorder:C.border}`,
          display:"flex", alignItems:"center", justifyContent:"center",
          transition:"transform 0.2s ease, border-color 0.15s",
          transform:open?"rotate(180deg)":"rotate(0deg)",
        }}>
