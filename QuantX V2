  const totalPnl = entries.reduce((sum, e) => sum + (e.pnl || 0), 0);
  const settled = entries.filter(e => e.outcome !== "pending");
  const winRate = settled.length > 0 ? ((wins / settled.length) * 100).toFixed(1) : null;

