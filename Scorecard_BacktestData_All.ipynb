      "source": [
        "# Combined portfolio daily P&L\n",
        "combined_daily = {}\n",
        "\n",
        "for pair in FINAL_PAIRS:\n",
        "    lead = pair[\"lead\"]\n",
        "    target = pair[\"target\"]\n",
        "\n",
        "    for i in range(1, len(opens)):\n",
        "        date = opens.index[i]\n",
        "        lpc = closes[lead].iloc[i-1]\n",
        "        lo_ = opens[lead].iloc[i]\n",
        "        tpc = closes[target].iloc[i-1]\n",
        "        tp  = opens[target].iloc[i]\n",
        "        if any(pd.isna([lpc, lo_, tpc, tp])):\n",
        "            continue\n",
        "        ol = lo_/lpc - 1\n",
        "        ot = tp/tpc - 1\n",
        "        shock = ol - pair[\"beta\"] * ot\n",
        "        pct = percentile_rank(pair[\"sk\"], shock)\n",
        "        if pct >= pair[\"th\"]:\n",
        "            direction = \"UP\"\n",
        "        elif pct <= pair[\"lo\"]:\n",
        "            direction = \"DN\"\n",
        "        else:\n",
        "            combined_daily[date] = combined_daily.get(date, 0)\n",
        "            continue\n",
        "        lead_qty   = 1000 / lo_\n",
        "        target_qty = 1000 / tp\n",
        "        lead_close   = closes[lead].iloc[i]\n",
        "        target_close = closes[target].iloc[i]\n",
        "        if direction == \"UP\":\n",
        "            pnl = -lead_qty*(lead_close-lo_) + target_qty*(target_close-tp)\n",
        "        else:\n",
        "            pnl = lead_qty*(lead_close-lo_) - target_qty*(target_close-tp)\n",
        "        combined_daily[date] = combined_daily.get(date, 0) + pnl\n",
        "\n",
        "pnl_arr = np.array(list(combined_daily.values()))\n",
        "avg = np.mean(pnl_arr)\n",
        "std = np.std(pnl_arr)\n",
        "downside = np.std(pnl_arr[pnl_arr < 0]) if len(pnl_arr[pnl_arr < 0]) > 0 else 1\n",
        "sharpe  = (avg / std) * np.sqrt(252) if std > 0 else 0\n",
        "sortino = (avg / downside) * np.sqrt(252) if downside > 0 else 0\n",
        "\n",
        "equity = [0]\n",
        "for p in pnl_arr:\n",
        "    equity.append(equity[-1] + p)\n",
        "peak = 0\n",
        "max_dd = 0\n",
        "for e in equity:\n",
        "    if e > peak:\n",
        "        peak = e\n",
        "    dd = peak - e\n",
        "    if dd > max_dd:\n",
        "        max_dd = dd\n",
        "\n",
        "print(f\"Combined Portfolio\")\n",
        "print(f\"Sharpe:  {sharpe:.2f}\")\n",
        "print(f\"Sortino: {sortino:.2f}\")\n",
        "print(f\"Max DD:  ${max_dd:.0f}\")"
